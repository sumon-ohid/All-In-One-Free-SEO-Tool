# ─────────────────────────────────────────────────────────────────────
# .gitignore — what NEVER goes to git.
#
# Anything regenerable (deps, build output) or per-install state
# (database, logs, OAuth tokens, encryption keys) is excluded. Code,
# config templates, docs, and migrations ARE tracked.
# ─────────────────────────────────────────────────────────────────────

# dependencies (regenerable via pnpm install)
/node_modules
/.pnpm-store

# build artifacts (regenerable via pnpm build)
/.next
/dist
/out
/build
/coverage
.turbo
.vercel
.swc

# TypeScript build incremental files
*.tsbuildinfo
next-env.d.ts

# OS metadata
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE state (per-developer; share via the repo's own configs instead)
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*~

# Certificates / signing
*.pem
*.key

# ─────────────────────────────────────────────────────────────────────
# USER DATA — NEVER commit. Each install creates its own.
# ─────────────────────────────────────────────────────────────────────

# SQLite database + WAL / shared-memory + auto-backups
data.db
data.db-shm
data.db-wal
data.db.bak
data.db.bak-*
*.sqlite
*.sqlite-*
/data/

# Tool-generated user assets (screenshots, exports, PDFs, etc.)
/public/uploads/
/screenshots/
/exports/

# OAuth refresh tokens / API-key encryption key — leakage = account compromise
.seo-encryption-key

# Per-instance runtime state
.seo-port
dev-server.log
dev-server.err.log
.dev-server.pid
.dev-server.cmd
.install-progress
# Junk files that have accidentally slipped in via bash heredoc /
# commit-message parsing in past sessions. Keeping them explicitly
# ignored so re-occurrences never get staged.
commit-msg.txt
/dev
/production
/3000)
/hard)

# Logs in general
*.log

# Redis dump (if Redis worker writes locally)
dump.rdb

# Desktop guides regenerated per install
*-Welcome.txt

# ─────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit.
# ─────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Note: .env.example IS tracked — it's the documented template.

# ─────────────────────────────────────────────────────────────────────
# Per-user tool config (Claude Code, scheduled-task locks, etc.)
# ─────────────────────────────────────────────────────────────────────
.claude/

# Internal project plan / Claude Code context — strategy, decision log,
# competitive analysis, pricing notes, validation outreach. Kept locally
# for the maintainer + Claude Code to reference; never committed.
CLAUDE.md

# pnpm config — read by pnpm 11+ on every command.
#
# Why this file exists:
# pnpm 11+ blocks native-module build scripts by default and FAILS the
# install if it sees any package whose post-install script was skipped.
# That makes installs brittle when:
#   - the project adds a new native dep someone forgot to allowlist
#   - a prior failed install left node_modules in a half-built state
#
# Our defense-in-depth:
#   1. package.json `pnpm.onlyBuiltDependencies` allowlists the packages
#      we KNOW need build scripts (better-sqlite3, sharp, esbuild,
#      tesseract.js, unrs-resolver, msw). Those ALWAYS get to build.
#   2. This file says: if anything else gets skipped, just warn — don't
#      kill the install. The user can still run `pnpm rebuild` later if
#      they need to.
ignored-builds-fail-install=false
